# Endpoint to query. Leave blank to use the local in-memory rdflib executor.
GRAPH_MCP_ENDPOINT_URL=

# Default LIMIT applied to SELECT queries when the plan does not specify one.
GRAPH_MCP_DEFAULT_LIMIT=100

# Hard maximum for any executed query.
GRAPH_MCP_MAX_LIMIT=1000

# Request timeout (milliseconds) per executed query.
GRAPH_MCP_TIMEOUT_MS=5000

# Comma-separated list of allowed named graph IRIs. Empty disables the GRAPH allowlist.
GRAPH_MCP_ALLOWED_GRAPHS=

# Comma-separated list of allowed SERVICE endpoint IRIs. Empty disables SERVICE entirely.
GRAPH_MCP_ALLOWED_SERVICE_ENDPOINTS=

# When true, exposes the execute_sparql_raw tool. Strongly discouraged in untrusted contexts.
GRAPH_MCP_ENABLE_RAW_SPARQL=false

# Maximum number of triple patterns in a single rendered query.
GRAPH_MCP_MAX_TRIPLE_PATTERNS=200

# Maximum nesting depth (groups, optionals, subqueries).
GRAPH_MCP_MAX_QUERY_DEPTH=8

# Maximum number of nodes in a property-path AST.
GRAPH_MCP_MAX_PROPERTY_PATH_COMPLEXITY=16

# When true, the renderer will emit unbounded property paths (NOT recommended).
GRAPH_MCP_ALLOW_UNBOUNDED_PATHS=false

# Path to a Turtle file loaded into the local executor at startup. Used for tests/demos.
GRAPH_MCP_LOCAL_GRAPH_FILE=

# Logging level (DEBUG, INFO, WARNING, ERROR).
GRAPH_MCP_LOG_LEVEL=INFO
